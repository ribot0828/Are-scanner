{
  "builds": [
    {
      "src": "api/races.py",
      "use": "@vercel/python"
    },
    {
      "src": "api/race.py",
      "use": "@vercel/python"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/races",
      "dest": "/api/races.py"
    },
    {
      "src": "/api/race",
      "dest": "/api/race.py"
    },
    {
      "src": "/",
      "dest": "/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "/$1"
    }
  ]
}
